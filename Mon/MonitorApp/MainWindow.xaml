<Window x:Class="MonitorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="USB麦克风录音监控大屏" Height="900" Width="1400"
        WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="StatusOnline" TargetType="Border">
            <Setter Property="Background" Value="#00C851"/>
            <Setter Property="CornerRadius" Value="50"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
        </Style>
        <Style x:Key="StatusOffline" TargetType="Border">
            <Setter Property="Background" Value="#FF4444"/>
            <Setter Property="CornerRadius" Value="50"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Background="#1a1a2e">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#16213e" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Margin="30,20,0,0">
                <TextBlock Text="🎤" FontSize="36" Margin="0,0,15,0"/>
                <TextBlock Text="分布式声学监测与分析平台" FontSize="28" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Label Content="服务器地址:" Foreground="#a0a0a0" Width="75" Height="36"/>
                <TextBox x:Name="txtServerIp" Text="127.0.0.1" Width="120" Height="35" 
                         Background="#2d3a4b" Foreground="White" BorderBrush="#4a5568" Margin="0,0,10,0"/>
                <Label Content="端口:" Foreground="#a0a0a0" Margin="0,0,10,0"/>
                <TextBox x:Name="txtPort" Text="8888" Width="60" Height="35" 
                         Background="#2d3a4b" Foreground="White" BorderBrush="#4a5568"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button x:Name="btnRefresh" Content="刷新状态" Width="120" Height="35" 
                        Background="#00d4ff" Foreground="Black" FontWeight="Bold"
                        Click="btnRefresh_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="pnlDevices" Orientation="Horizontal" Margin="0,0,0,20" HorizontalAlignment="Left"/>
            </ScrollViewer>

            <Border Grid.Column="1" Background="#16213e" CornerRadius="10" Margin="20,0,0,0">
                <StackPanel Margin="20">
                    <TextBlock Text="📁 最近上传文件" FontSize="18" Foreground="White" FontWeight="Bold" Margin="0,0,0,15"/>
                    <ListBox x:Name="lstFiles" Background="#2d3a4b" Foreground="White" Height="500"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="5" Background="#1a1a2e" CornerRadius="5">
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="{Binding MicId}" Width="40" Foreground="#00d4ff"/>
                                        <TextBlock Text="{Binding Name}" Width="280" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <Label Content="设备总数:" Foreground="#a0a0a0"/>
                        <Label x:Name="lblTotalDevices" Content="0" Foreground="#00d4ff" Margin="10,0,20,0"/>
                        <Label Content="文件总数:" Foreground="#a0a0a0"/>
                        <Label x:Name="lblTotalFiles" Content="0" Foreground="#00C851" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2" Background="#16213e">
            <StatusBarItem>
                <TextBlock x:Name="lblStatus" Foreground="#a0a0a0"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="lblLastUpdate" Foreground="#a0a0a0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>